<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_CambioAtlantico"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Cambio Atlántico (proceso actual)" processRef="Process_1" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Operador" name="Operador">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_7</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_8</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Cliente escribe por mensajería">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_2" name="Operador copia cotización al chat">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_3" name="¿Opera o consulta?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Consultar</bpmn:outgoing>
      <bpmn:outgoing>Flow_Operar</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_4" name="Preguntar si compra o vende">
      <bpmn:incoming>Flow_Operar</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_5" name="Consultar stock en el sistema">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_6" name="Cerrar y registrar la operación">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_7" name="Operación finalizada">
      <bpmn:incoming>Flow_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_8" name="Consulta respondida">
      <bpmn:incoming>Flow_Consultar</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="Annotation_1">
      <bpmn:text>Cuello de botella: depende del operador</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_2">
      <bpmn:text>Cuello de botella: depende del operador</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" sourceRef="Annotation_1" targetRef="Task_2" />
    <bpmn:association id="Association_2" sourceRef="Annotation_2" targetRef="Task_6" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_2" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_2" targetRef="Gateway_3" />
    <bpmn:sequenceFlow id="Flow_Consultar" name="Solo consultar" sourceRef="Gateway_3" targetRef="EndEvent_8" />
    <bpmn:sequenceFlow id="Flow_Operar" name="Quiere operar" sourceRef="Gateway_3" targetRef="Task_4" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_4" targetRef="Task_5" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_5" targetRef="Task_6" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_6" targetRef="EndEvent_7" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_1_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="160" y="40" width="1080" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Operador_di" bpmnElement="Lane_Operador" isHorizontal="true">
        <dc:Bounds x="190" y="40" width="1050" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="240" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="222" y="235" width="80" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_2_di" bpmnElement="Task_2">
        <dc:Bounds x="320" y="170" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_3_di" bpmnElement="Gateway_3" isMarkerVisible="true">
        <dc:Bounds x="500" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="486" y="155" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_4_di" bpmnElement="Task_4">
        <dc:Bounds x="610" y="170" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_5_di" bpmnElement="Task_5">
        <dc:Bounds x="780" y="170" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_6_di" bpmnElement="Task_6">
        <dc:Bounds x="950" y="170" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_7_di" bpmnElement="EndEvent_7">
        <dc:Bounds x="1120" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1100" y="235" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_8_di" bpmnElement="EndEvent_8">
        <dc:Bounds x="507" y="300" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="487" y="340" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Annotation_1_di" bpmnElement="Annotation_1">
        <dc:Bounds x="320" y="70" width="160" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Annotation_2_di" bpmnElement="Annotation_2">
        <dc:Bounds x="950" y="70" width="160" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="276" y="210" /><di:waypoint x="320" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="210" /><di:waypoint x="500" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Operar_di" bpmnElement="Flow_Operar">
        <di:waypoint x="550" y="210" /><di:waypoint x="610" y="210" />
        <bpmndi:BPMNLabel><dc:Bounds x="556" y="192" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Consultar_di" bpmnElement="Flow_Consultar">
        <di:waypoint x="525" y="235" /><di:waypoint x="525" y="300" />
        <bpmndi:BPMNLabel><dc:Bounds x="531" y="255" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="730" y="210" /><di:waypoint x="780" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="900" y="210" /><di:waypoint x="950" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="1070" y="210" /><di:waypoint x="1120" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Association_1_di" bpmnElement="Association_1">
        <di:waypoint x="400" y="120" /><di:waypoint x="385" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Association_2_di" bpmnElement="Association_2">
        <di:waypoint x="1030" y="120" /><di:waypoint x="1015" y="170" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
